      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "serverName": "vpn.lab.local",
          "allowInsecure": true,
          "alpn": ["h2"]
        }
      }
    }
  ],
  "routing": {
    "rules": [
      {
