{
  "log": { "loglevel": "debug" },
  "inbounds": [
    {
      "tag": "dns-in",
      "listen": "127.0.0.1",
      "port": 5304,
      "protocol": "dokodemo-door",
      "settings": {
        "address": "1.1.1.1",
        "port": 53,
        "network": "udp"
      }
    }
  ],
  "outbounds": [
    {
      "tag": "tt-out",
      "protocol": "trusttunnel",
      "settings": {
        "address": "127.0.0.1",
        "port": 9444,
        "username": "u1",
        "password": "p1",
        "hostname": "vpn.lab.local",
        "transport": "http2",
        "hasIpv6": true,
        "skipVerification": false,
        "certificatePemFile": "/opt/lab/xray-tt/official-endpoint-lab/certs/cert.pem",
        "clientRandom": "",
        "antiDpi": false,
        "udp": true
