{
  "log": { "loglevel": "debug" },
  "inbounds": [
    {
      "tag": "tun-in",
      "protocol": "tun",
      "settings": {
        "name": "xraytunh2",
        "MTU": 1500
      }
    }
  ],
  "outbounds": [
    {
      "tag": "tt-out",
      "protocol": "trusttunnel",
      "settings": {
        "address": "127.0.0.1",
        "port": 9443,
        "username": "u1",
        "password": "p1",
        "hostname": "vpn.lab.local",
        "transport": "http2",
        "hasIpv6": true,
        "skipVerification": false,
        "certificatePemFile": "/opt/lab/xray-tt/certs/server.crt",
        "clientRandom": "",
        "antiDpi": false,
        "udp": false
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "serverName": "vpn.lab.local",
          "allowInsecure": true,
          "alpn": ["h2"]
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom"
    }
  ],
  "routing": {
    "rules": [
      {
        "type": "field",
        "inboundTag": ["tun-in"],
        "outboundTag": "tt-out"
      }
    ]
  }
}
